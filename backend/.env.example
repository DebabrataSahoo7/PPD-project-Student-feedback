# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL (Neon) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── Initial Admin Seed ────────────────────────────────────────
# Run: npm run seed
# These credentials will be used to create the first admin account
ADMIN_EMAIL=admin@yourinstitution.edu
ADMIN_PASSWORD=ChangeThisPassword@123

# ── App Base URL ──────────────────────────────────────────────
APP_BASE_URL=https://your-frontend.vercel.app

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=https://your-frontend.vercel.app

# ── Email (Nodemailer + Gmail SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="FormBit <your_gmail@gmail.com>"
